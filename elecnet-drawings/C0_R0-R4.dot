graph composition {
  rankdir=LR;
  label="R0 ↔ R4 (9 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R0 (src)"; style=filled; color="#cce5ff";
    "mildura.nodec" [label="", shape=circle, style=filled, fillcolor=white];

  }
  subgraph cluster_tgt {
    label="R4 (tgt)"; style=filled; color="#fde2b8";
    "echuca.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "echuca.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "echuca.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "echuca.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "mildura.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "echuca.gw" -- "mildura.agg";
    "echuca.gen.n2" -- "echuca.gw";
    "echuca.gen.n3" -- "echuca.gw";
    "echuca.gen.n1" -- "echuca.gw";
  }
  "mildura.agg" -- "mildura.nodec" [color=red, penwidth=2.0];
}
