graph composition {
  rankdir=LR;
  label="R2 ↔ R4 (9 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R2 (src)"; style=filled; color="#cce5ff";
    "adelaide.site_dc2.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.ess" -- "adelaide.site_dc2.gw";
    "adelaide.site_dc2.eme" -- "adelaide.site_dc2.gw";
  }
  subgraph cluster_tgt {
    label="R4 (tgt)"; style=filled; color="#fde2b8";
    "adelaide.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "geraldton.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "kalbarri.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "kalbarri.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "kalbarri.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "perth.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "kalbarri.gen.n2" -- "kalbarri.gw";
    "kalbarri.gen.n1" -- "kalbarri.gw";
    "geraldton.agg" -- "perth.core_1";
    "geraldton.agg" -- "kalbarri.gw";
    "adelaide.core_1" -- "perth.core_1";
  }
  "adelaide.core_1" -- "adelaide.site_dc2.gw" [color=red, penwidth=2.0];
}
