graph composition {
  rankdir=LR;
  label="R4 ↔ R5 (4 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R4 (src)"; style=filled; color="#cce5ff";
    "brisbane.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "mackay.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n2" -- "innisfail.gw";
    "innisfail.gen.n1" -- "innisfail.gw";
    "brisbane.core_2" -- "sydney.core_2";
    "innisfail.gw" -- "mackay.agg";
    "brisbane.core_2" -- "mackay.agg";
  }
  subgraph cluster_tgt {
    label="R5 (tgt)"; style=filled; color="#fde2b8";
    "dubbo.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc2.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.ess" -- "sydney.site_dc1.gw";
    "sydney.core_1" -- "sydney.site_dc2.gw";
    "dubbo.agg" -- "sydney.core_1";
    "sydney.core_1" -- "sydney.site_dc1.gw";
    "sydney.site_dc2.eme" -- "sydney.site_dc2.gw";
  }
  "sydney.core_1" -- "sydney.core_2" [color=red, penwidth=2.0];
  "sydney.core_2" -- "sydney.site_dc1.gw" [color=red, penwidth=2.0];
  "sydney.core_2" -- "sydney.site_dc2.gw" [color=red, penwidth=2.0];
  "dubbo.agg" -- "sydney.core_2" [color=red, penwidth=2.0];
}
