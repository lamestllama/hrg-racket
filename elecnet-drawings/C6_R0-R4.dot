graph composition {
  rankdir=LR;
  label="R0 ↔ R4 (6 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R0 (src)"; style=filled; color="#cce5ff";
    "canberra.core_1" [label="", shape=circle, style=filled, fillcolor=white];

  }
  subgraph cluster_tgt {
    label="R4 (tgt)"; style=filled; color="#fde2b8";
    "dubbo.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.site_dc1.ess" -- "sydney.site_dc1.gw";
    "sydney.core_1" -- "sydney.site_dc2.gw";
    "dubbo.agg" -- "sydney.core_1";
    "sydney.core_1" -- "sydney.site_dc1.gw";
  }
  "canberra.core_1" -- "sydney.core_1" [color=red, penwidth=2.0];
}
