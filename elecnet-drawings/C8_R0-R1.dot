graph composition {
  rankdir=LR;
  label="R0 ↔ R1 (1 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R0 (src)"; style=filled; color="#cce5ff";
    "melbourne.core_2" [label="", shape=circle, style=filled, fillcolor=white];

  }
  subgraph cluster_tgt {
    label="R1 (tgt)"; style=filled; color="#fde2b8";
    "hobart.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "hobart.nodec" [label="", shape=circle, style=filled, fillcolor=white];
    "hobart.agg" -- "hobart.nodec";
  }
  "hobart.agg" -- "melbourne.core_2" [color=red, penwidth=2.0];
}
