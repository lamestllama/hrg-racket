graph composition {
  rankdir=LR;
  label="R2 ↔ R4 (2 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R2 (src)"; style=filled; color="#cce5ff";
    "melbourne.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.site_dc2.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.site_dc2.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.site_dc2.eme" -- "melbourne.site_dc2.gw";
    "melbourne.core_2" -- "melbourne.site_dc2.gw";
    "melbourne.site_dc2.ess" -- "melbourne.site_dc2.gw";
  }
  subgraph cluster_tgt {
    label="R4 (tgt)"; style=filled; color="#fde2b8";
    "franklin.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "hobart.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n2" -- "franklin.gw";
    "franklin.gen.n3" -- "franklin.gw";
    "franklin.gw" -- "hobart.agg";
    "franklin.gen.n1" -- "franklin.gw";
  }
  "hobart.agg" -- "melbourne.core_2" [color=red, penwidth=2.0];
}
