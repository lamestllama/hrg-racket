graph rule {
  label="R3 — 4n, tentacles=(3), 3e";
  labelloc=t;
  fontname=Helvetica;
  node [fontname=Helvetica];
  n0 [label="0", style=filled, fillcolor="#cce5ff", shape=circle];
  n1 [label="1", style=filled, fillcolor="#cce5ff", shape=circle];
  n2 [label="2", style=filled, fillcolor="#cce5ff", shape=circle];
  n3 [label="3", style=filled, fillcolor="#f8b4b4", shape=doublecircle];
  n0 -- n3;
  n1 -- n3;
  n2 -- n3;
}
