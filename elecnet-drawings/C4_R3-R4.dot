graph composition {
  rankdir=LR;
  label="R3 ↔ R4 (3 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R3 (src)"; style=filled; color="#cce5ff";
    "dotswood.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "dotswood.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "dotswood.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "dotswood.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "dotswood.gen.n1" -- "dotswood.gw";
    "dotswood.gen.n2" -- "dotswood.gw";
    "dotswood.gen.n3" -- "dotswood.gw";
  }
  subgraph cluster_tgt {
    label="R4 (tgt)"; style=filled; color="#fde2b8";
    "clermont.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "clermont.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "clermont.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "clermont.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "mackay.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "clermont.gen.n1" -- "clermont.gw";
    "clermont.gw" -- "mackay.agg";
    "clermont.gen.n2" -- "clermont.gw";
    "clermont.gen.n3" -- "clermont.gw";
  }
  "dotswood.gw" -- "mackay.agg" [color=red, penwidth=2.0];
}
