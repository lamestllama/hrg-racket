graph composition {
  rankdir=LR;
  label="R3 ↔ R5 (9 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R3 (src)"; style=filled; color="#cce5ff";
    "newman.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "newman.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "newman.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "newman.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "newman.gen.n2" -- "newman.gw";
    "newman.gen.n1" -- "newman.gw";
    "newman.gen.n3" -- "newman.gw";
  }
  subgraph cluster_tgt {
    label="R5 (tgt)"; style=filled; color="#fde2b8";
    "barrow_island.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "barrow_island.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "barrow_island.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "karratha.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "perth.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "perth.site_dc1.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "karratha.agg" -- "perth.core_2";
    "perth.core_2" -- "perth.site_dc1.gw";
    "barrow_island.gw" -- "karratha.agg";
    "barrow_island.gen.n1" -- "barrow_island.gw";
    "barrow_island.gen.n2" -- "barrow_island.gw";
  }
  "karratha.agg" -- "newman.gw" [color=red, penwidth=2.0];
}
