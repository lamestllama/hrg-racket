graph rule {
  label="R2 — 6n, tentacles=(0 1 5), 5e";
  labelloc=t;
  fontname=Helvetica;
  node [fontname=Helvetica];
  n0 [label="0", style=filled, fillcolor="#f8b4b4", shape=doublecircle];
  n1 [label="1", style=filled, fillcolor="#f8b4b4", shape=doublecircle];
  n2 [label="2", style=filled, fillcolor="#cce5ff", shape=circle];
  n3 [label="3", style=filled, fillcolor="#cce5ff", shape=circle];
  n4 [label="4", style=filled, fillcolor="#cce5ff", shape=circle];
  n5 [label="5", style=filled, fillcolor="#f8b4b4", shape=doublecircle];
  n0 -- n1;
  n0 -- n5;
  n1 -- n2;
  n2 -- n3;
  n2 -- n4;
}
