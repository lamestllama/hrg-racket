graph composition {
  rankdir=LR;
  label="R4 ↔ R5 (2 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R4 (src)"; style=filled; color="#cce5ff";
    "franklin.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n3" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "hobart.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "franklin.gen.n2" -- "franklin.gw";
    "franklin.gen.n3" -- "franklin.gw";
    "franklin.gw" -- "hobart.agg";
    "franklin.gen.n1" -- "franklin.gw";
  }
  subgraph cluster_tgt {
    label="R5 (tgt)"; style=filled; color="#fde2b8";
    "horsham.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "horsham.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "horsham.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.site_dc1.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "mildura.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "melbourne.core_1" -- "melbourne.site_dc1.gw";
    "horsham.gen.n1" -- "horsham.gw";
    "horsham.gen.n2" -- "horsham.gw";
    "melbourne.core_1" -- "mildura.agg";
    "horsham.gw" -- "mildura.agg";
  }
  "hobart.agg" -- "melbourne.core_1" [color=red, penwidth=2.0];
}
