graph composition {
  rankdir=LR;
  label="R2 ↔ R5 (23 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R2 (src)"; style=filled; color="#cce5ff";
    "brisbane.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "brisbane.site_dc2.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "brisbane.site_dc2.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "brisbane.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "brisbane.site_dc2.ess" -- "brisbane.site_dc2.gw";
    "brisbane.site_dc2.eme" -- "brisbane.site_dc2.gw";
    "brisbane.core_1" -- "brisbane.site_dc2.gw";
  }
  subgraph cluster_tgt {
    label="R5 (tgt)"; style=filled; color="#fde2b8";
    "brisbane.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n1" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "mackay.agg" [label="", shape=circle, style=filled, fillcolor=white];
    "sydney.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "innisfail.gen.n2" -- "innisfail.gw";
    "innisfail.gen.n1" -- "innisfail.gw";
    "brisbane.core_2" -- "sydney.core_2";
    "innisfail.gw" -- "mackay.agg";
    "brisbane.core_2" -- "mackay.agg";
  }
  "brisbane.core_2" -- "brisbane.site_dc2.gw" [color=red, penwidth=2.0];
  "brisbane.core_1" -- "brisbane.core_2" [color=red, penwidth=2.0];
  "brisbane.core_1" -- "mackay.agg" [color=red, penwidth=2.0];
}
