graph composition {
  rankdir=LR;
  label="R0 ↔ R0 (6 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R0 (src)"; style=filled; color="#cce5ff";
    "a.g1" [label="", shape=circle, style=filled, fillcolor=white];
    "a.g2" [label="", shape=circle, style=filled, fillcolor=white];
    "a.g1" -- "a.g2";
  }
  subgraph cluster_tgt {
    label="R0 (tgt)"; style=filled; color="#fde2b8";
    "a.gm1" [label="", shape=circle, style=filled, fillcolor=white];
    "a.r1" [label="", shape=circle, style=filled, fillcolor=white];
    "a.gm1" -- "a.r1";
  }
  "a.g1" -- "a.gm1" [color=red, penwidth=2.0];
}
