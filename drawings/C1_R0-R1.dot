graph composition {
  rankdir=LR;
  label="R0 ↔ R1 (10 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R0 (src)"; style=filled; color="#cce5ff";
    "a.o1" [label="", shape=circle, style=filled, fillcolor=white];
    "a.o2" [label="", shape=circle, style=filled, fillcolor=white];
    "a.o1" -- "a.o2";
  }
  subgraph cluster_tgt {
    label="R1 (tgt)"; style=filled; color="#fde2b8";
    "o.B1" [label="", shape=circle, style=filled, fillcolor=white];
    "o.B2" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C1" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C2" [label="", shape=circle, style=filled, fillcolor=white];
    "o.D" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C1" -- "o.C2";
    "o.B2" -- "o.C1";
    "o.B1" -- "o.C2";
    "o.B2" -- "o.C2";
    "o.B1" -- "o.B2";
    "o.C2" -- "o.D";
    "o.C1" -- "o.D";
    "o.B1" -- "o.C1";
  }
  "a.o1" -- "o.B1" [color=red, penwidth=2.0];
  "a.o2" -- "o.B2" [color=red, penwidth=2.0];
}
