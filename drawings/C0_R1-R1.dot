graph composition {
  rankdir=LR;
  label="R1 ↔ R1 (2 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R1 (src)"; style=filled; color="#cce5ff";
    "o.B1" [label="", shape=circle, style=filled, fillcolor=white];
    "o.B2" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C1" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C2" [label="", shape=circle, style=filled, fillcolor=white];
    "o.D" [label="", shape=circle, style=filled, fillcolor=white];
    "o.C1" -- "o.C2";
    "o.B2" -- "o.C1";
    "o.B1" -- "o.C2";
    "o.B2" -- "o.C2";
    "o.B1" -- "o.B2";
    "o.C2" -- "o.D";
    "o.C1" -- "o.D";
    "o.B1" -- "o.C1";
  }
  subgraph cluster_tgt {
    label="R1 (tgt)"; style=filled; color="#fde2b8";
    "r.B1" [label="", shape=circle, style=filled, fillcolor=white];
    "r.B2" [label="", shape=circle, style=filled, fillcolor=white];
    "r.C1" [label="", shape=circle, style=filled, fillcolor=white];
    "r.C2" [label="", shape=circle, style=filled, fillcolor=white];
    "r.D" [label="", shape=circle, style=filled, fillcolor=white];
    "r.B1" -- "r.C1";
    "r.B1" -- "r.B2";
    "r.B2" -- "r.C1";
    "r.B1" -- "r.C2";
    "r.B2" -- "r.C2";
    "r.B1" -- "r.D";
    "r.B2" -- "r.D";
    "r.C1" -- "r.C2";
  }
  "o.B1" -- "r.B2" [color=red, penwidth=2.0];
}
