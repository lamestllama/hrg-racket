graph composition {
  rankdir=LR;
  label="R2 ↔ R2 (35 uses)";
  labelloc=t;
  fontname=Helvetica;
  subgraph cluster_src {
    label="R2 (src)"; style=filled; color="#cce5ff";
    "adelaide.core_1" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc2.ess" -- "adelaide.site_dc2.gw";
    "adelaide.core_1" -- "adelaide.site_dc2.gw";
    "adelaide.site_dc2.eme" -- "adelaide.site_dc2.gw";
  }
  subgraph cluster_tgt {
    label="R2 (tgt)"; style=filled; color="#fde2b8";
    "adelaide.core_2" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc1.eme" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc1.ess" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.site_dc1.gw" [label="", shape=circle, style=filled, fillcolor=white];
    "adelaide.core_2" -- "adelaide.site_dc1.gw";
    "adelaide.site_dc1.eme" -- "adelaide.site_dc1.gw";
    "adelaide.site_dc1.ess" -- "adelaide.site_dc1.gw";
  }
  "adelaide.core_1" -- "adelaide.site_dc1.gw" [color=red, penwidth=2.0];
  "adelaide.core_1" -- "adelaide.core_2" [color=red, penwidth=2.0];
}
